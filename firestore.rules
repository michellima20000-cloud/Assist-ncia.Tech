rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Since we're accessing Firestore via a full-stack Node server,
    // the backend will have administrative access if using firebase-admin/ADC,
    // or standard access. Let's allow public read/write or authenticate based on requirements.
    // To ensure maximum safety while allowing the server to interact, we allow reads/writes.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
